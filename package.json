{
  "name": "ml-array-utils",
  "private": true,
  "version": "1.0.0",
  "description": "Functional utilities to transform and compute stats on arrays",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build-lerna",
    "build-lerna": "npm run build-lerna-clean && npm run tsc",
    "build-lerna-clean": "npm run tsc -- --clean",
    "eslint": "eslint packages --cache",
    "eslint-fix": "npm run eslint -- --fix",
    "prettier": "prettier --check .",
    "prettier-write": "prettier --write .",
    "publish": "npm run build-lerna && npm run test && lerna publish -y --no-verify-access",
    "test": "npm run test-only && npm run eslint && npm run prettier",
    "test-only": "npm run build-lerna && vitest --run --test-timeout=30000 --coverage",
    "tsc": "tsc --build",
    "tsc-watch": "tsc --build --watch"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@zakodium/tsconfig": "^1.0.5",
    "eslint": "^9.39.4",
    "eslint-config-cheminfo-typescript": "^21.2.0",
    "lerna": "^9.0.5",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
